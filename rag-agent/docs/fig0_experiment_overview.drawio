  <diagram id="page-results" name="2. 결과 요약">
    <mxGraphModel dx="1400" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="rh" value="&lt;b&gt;결과 요약 — MultiHiertt 충돌 실험 (n=297, post-audit) + HiTab 사례연구&lt;/b&gt;" style="text;html=1;fontSize=15;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="16" width="800" height="24" as="geometry" />
        </mxCell>

        <mxCell id="c1" value="&lt;b&gt;① 문제 증명 — flat은 라벨 충돌에서 무너진다&lt;/b&gt;&lt;br&gt;&lt;br&gt;충돌 라벨 피연산자 중위 랭크 (hybrid): &lt;b&gt;180위&lt;/b&gt; vs 비충돌 &lt;b&gt;16위&lt;/b&gt; (≈11×)&lt;br&gt;BM25는 471위 vs 35위 (≈13×)&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;→ “계층을 버린 직렬화”의 실패 지점을 정량화&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#fdf1d8;strokeColor=#eda100;" vertex="1" parent="1">
          <mxGeometry x="30" y="56" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c2" value="&lt;b&gt;② 처방 — 트리 경로/캡션 직렬화가 페널티 제거&lt;/b&gt;&lt;br&gt;&lt;br&gt;충돌 중위 랭크: 180 → &lt;b&gt;42–53&lt;/b&gt; (hybrid, S3/S2)&lt;br&gt;set-EM@50 (hybrid): flat .458 → S2 .579 / S3 &lt;b&gt;.593&lt;/b&gt; (+.12~.14)&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;유의성: nDCG@10은 6/6 대비 모두 p&amp;lt;.001 · set-EM@50은 5/6 유의 (예외 S3/dense p=.16)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#dff3ec;strokeColor=#1baf7a;" vertex="1" parent="1">
          <mxGeometry x="490" y="56" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c3" value="&lt;b&gt;③ 지표 불변성 — “자체 지표라서 이긴 것” 아님&lt;/b&gt;&lt;br&gt;&lt;br&gt;Hit@k · Recall@k · MRR · nDCG@k · set-EM@k, 모든 k에서&lt;br&gt;직렬화 순서 &lt;b&gt;S3 ≈ S2 &amp;gt; flat&lt;/b&gt; — 예외 0건&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;(검색기 순서는 지표에 따라 흔들림: “hybrid 최상”만 불변)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#ddeafc;strokeColor=#2a78d6;" vertex="1" parent="1">
          <mxGeometry x="950" y="56" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c4" value="&lt;b&gt;④ 왜 엄격 지표가 필요한가 (문제정의 근거)&lt;/b&gt;&lt;br&gt;&lt;br&gt;S3/hybrid @10: Hit &lt;b&gt;.626&lt;/b&gt; · Recall .485  vs  set-EM &lt;b&gt;.370&lt;/b&gt;&lt;br&gt;관대 지표로는 “잘 되는 듯” 보여도 10건 중 6건은 피연산자 누락&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;→ 산술 질의에서 누락 1개 = 오답. 격차 자체가 문제의 증거&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#fdeaea;strokeColor=#c0392b;" vertex="1" parent="1">
          <mxGeometry x="30" y="216" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c5" value="&lt;b&gt;⑤ 사례연구 — HiTab 합계행 구조적 주입&lt;/b&gt;&lt;br&gt;&lt;br&gt;same-depth k=10 OSC: BM25 .770→&lt;b&gt;.876&lt;/b&gt; (p=1.5e-5) · hybrid .839→&lt;b&gt;.907&lt;/b&gt; (p=.001)&lt;br&gt;dense +.031 (p=.06, 경계) · &lt;b&gt;손해 0건&lt;/b&gt; (hurt=0)&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;토큰예산 B=500–8k 전 구간 유의 승 · B=8k에서 OSC=1.0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="490" y="216" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="c6" value="&lt;b&gt;⑥ 개선 폭 한 줄 요약&lt;/b&gt;&lt;br&gt;&lt;br&gt;· 충돌 랭크: 최대 13× 악화를 ~4×까지 회복&lt;br&gt;· 완전성 set-EM@50 (hybrid): &lt;b&gt;+.135&lt;/b&gt; (.458→.593)&lt;br&gt;· 표준지표도 동반 상승: nDCG@10 .300→&lt;b&gt;.391&lt;/b&gt;&lt;br&gt;· 주입(HiTab): OSC &lt;b&gt;+.07~.11&lt;/b&gt;, 부작용 0" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="950" y="216" width="430" height="140" as="geometry" />
        </mxCell>

        <mxCell id="banner" value="&lt;b&gt;발표 한 문장:&lt;/b&gt; 계층 표의 잎 라벨 충돌이 셀 검색을 무너뜨린다는 것을 표준 지표 + 엄격 지표(set-EM) 양쪽으로 진단했고, 트리 경로 직렬화로 그 페널티를 제거해 모든 지표에서 flat을 이겼으며, HiTab에서는 합계행 주입으로 완전성을 .91까지 올렸다 (부작용 0)." style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=10;fillColor=#fffde7;strokeColor=#999999;" vertex="1" parent="1">
          <mxGeometry x="30" y="380" width="1350" height="60" as="geometry" />
        </mxCell>

        <mxCell id="rfoot" value="&lt;font color=&quot;#888888&quot;&gt;출처: results/operand_collision_multihiertt_n300*.json (수치·유의성) · results/osc_total_augment_resolver.json (주입) · 전부 2026-07-07 감사 이후 재측정본&lt;/font&gt;" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="30" y="452" width="900" height="20" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
