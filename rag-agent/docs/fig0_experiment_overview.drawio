        <mxCell id="a10" value="&lt;font color=&quot;#bbbbbb&quot;&gt;“”&lt;/font&gt;" style="rounded=0;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="505" y="194" width="110" height="26" as="geometry" /></mxCell>
