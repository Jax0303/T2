        <mxCell id="b22" value="1,320" style="rounded=0;html=1;fontSize=12;fillColor=#ffffff;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="295" y="220" width="80" height="26" as="geometry" /></mxCell>
        <mxCell id="befNote" value="&lt;font style=&quot;font-size:11px&quot; color=&quot;#8a6d1a&quot;&gt;one cell covering 2 columns&lt;/font&gt;" style="text;html=1;align=center;" vertex="1" parent="1">
