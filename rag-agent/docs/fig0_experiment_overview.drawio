        <!-- ===== 3 pipelines ===== -->
        <mxCell id="pFlat" value="&lt;b&gt;P1 · flat — 잎(leaf) 라벨만&lt;/b&gt;&lt;br&gt;“Product X 2019: 1,320”&lt;br&gt;“Product X 2019: 1,020”&lt;br&gt;&lt;font color=&quot;#c0392b&quot;&gt;→ 두 셀이 사실상 동일 텍스트 = 검색기가 구분 불가&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=8;fillColor=#fdf1d8;strokeColor=#eda100;" vertex="1" parent="1">
