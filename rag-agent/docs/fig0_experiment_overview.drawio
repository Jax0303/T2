        <mxCell id="eP3C" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#2a78d6;" edge="1" parent="1" source="pS3" target="corpus"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eC2R1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;" edge="1" parent="1" source="corpus" target="rBm25"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eC2R2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;" edge="1" parent="1" source="corpus" target="rDense"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eC2R3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;" edge="1" parent="1" source="corpus" target="rHyb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eQ2R" value="top-k 셀 검색" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="qbox" target="rBm25">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="155" y="485" /></Array></mxGeometry>
        </mxCell>

        <!-- ===== metrics ===== -->
        <mxCell id="mStd" value="&lt;b&gt;문헌 표준 지표 (경쟁 논문들이 쓰는 채점)&lt;/b&gt;&lt;br&gt;Hit@k · Recall@k · MRR · nDCG@k&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;MT2Net: recall@10 · FT-RAG: Hit Rate@1 · Topo-RAG: nDCG@10 · MixRAG: HiT@1&lt;br&gt;→ 전부 부분 적중을 인정하는 &lt;b&gt;관대한&lt;/b&gt; 채점&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=8;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="990" y="50" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="mStrict" value="&lt;b&gt;엄격 지표: set-EM@k (= OSC) — 문제정의용&lt;/b&gt;&lt;br&gt;gold 피연산자 셀이 &lt;b&gt;전부&lt;/b&gt; top-k 안 ⇒ 1, 하나라도 빠지면 0&lt;br&gt;&lt;font color=&quot;#666666&quot;&gt;계보: HotpotQA Sup-EM · MDR Passage-EM · Beam Retrieval EM&lt;br&gt;(멀티홉 검색의 all-or-nothing 관행을 셀 단위에 적용)&lt;/font&gt;&lt;br&gt;산술 질의는 피연산자 1개만 빠져도 오답 → &lt;b&gt;완전성 = 정답 가능성&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=8;fillColor=#fdeaea;strokeColor=#c0392b;" vertex="1" parent="1">
          <mxGeometry x="990" y="190" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="mNote" value="&lt;font color=&quot;#888888&quot;&gt;두 지표군을 &lt;b&gt;같은 검색 기록&lt;/b&gt;에서 동시에 계산&lt;br&gt;→ “자체 지표라서 이긴 것” 반박 가능 (2페이지 ③)&lt;/font&gt;" style="text;html=1;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="990" y="330" width="380" height="34" as="geometry" />
