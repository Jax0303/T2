        <mxCell id="ps2N" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#0e6b4a&quot;&gt;②에서 복원한 &lt;b&gt;열 경로&lt;/b&gt;를 그대로 텍스트에 붙임 — &lt;b&gt;조상 라벨(Americas/Europe)이 두 청크를 구분&lt;/b&gt;. 질의의 “합” 대상인 두 셀이 서로 다른 청크로 검색된다&lt;/font&gt;" style="text;html=1;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="1112" y="444" width="450" height="56" as="geometry" />
        </mxCell>

        <!-- P3 S3 -->
        <mxCell id="ps3" value="&lt;font style=&quot;font-size:14px&quot;&gt;&lt;b&gt;P3 · S3 — 캡션 문장(caption sentence) 직렬화&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ddeafc;strokeColor=#2a78d6;" vertex="1" parent="1">
          <mxGeometry x="1094" y="538" width="482" height="190" as="geometry" />
        </mxCell>
        <mxCell id="ps31" value="&lt;font style=&quot;font-size:13px&quot;&gt;“For Product X, &lt;font color=&quot;#2a78d6&quot;&gt;&lt;b&gt;Americas&lt;/b&gt;&lt;/font&gt; &gt; 2019 is &lt;font color=&quot;#8a6d1a&quot;&gt;&lt;b&gt;1,320&lt;/b&gt;&lt;/font&gt;.”&lt;/font&gt;" style="rounded=0;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#2a78d6;" vertex="1" parent="1">
          <mxGeometry x="1112" y="574" width="446" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ps32" value="&lt;font style=&quot;font-size:13px&quot;&gt;“For Product X, &lt;font color=&quot;#2a78d6&quot;&gt;&lt;b&gt;Europe&lt;/b&gt;&lt;/font&gt; &gt; 2019 is &lt;font color=&quot;#8a6d1a&quot;&gt;&lt;b&gt;1,020&lt;/b&gt;&lt;/font&gt;.”&lt;/font&gt;" style="rounded=0;html=1;align=left;spacingLeft=10;fillColor=#ffffff;strokeColor=#2a78d6;" vertex="1" parent="1">
          <mxGeometry x="1112" y="610" width="446" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ps3N" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#1a4f8f&quot;&gt;같은 경로 정보를 &lt;b&gt;자연어 문장&lt;/b&gt;으로 표현 — dense 임베더가 학습한 텍스트 분포에 가까운 형태. 정보량은 S2와 동일, 표현만 다름&lt;/font&gt;" style="text;html=1;align=left;spacingLeft=4;" vertex="1" parent="1">
          <mxGeometry x="1112" y="652" width="450" height="56" as="geometry" />
        </mxCell>

        <!-- next-step strip -->
        <mxCell id="nextStrip" value="&lt;font style=&quot;font-size:12px&quot; color=&quot;#555555&quot;&gt;다음 단계: 세 표현을 &lt;b&gt;동일한 질의·동일한 검색기&lt;/b&gt;(BM25 / dense / hybrid)로 셀 단위 검색해 비교 — 결과 수치는 다음 슬라이드&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;spacing=8;fillColor=#f5f5f5;strokeColor=#bbbbbb;" vertex="1" parent="1">
          <mxGeometry x="1094" y="748" width="482" height="52" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page-pipeline-en" name="Pipeline">
